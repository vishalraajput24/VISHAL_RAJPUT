// ════════════════════════════════════════════════════════════════════════════
// V12 VISHAL RAJPUT — FULL STRATEGY (Pine v6)  ·  NIFTY 50 INDEX, 5-minute
// ----------------------------------------------------------------------------
// Runs the COMPLETE V12 strategy on the NIFTY 50 index itself — signal AND
// trade are both on the index. No futures, no option premium.
//
//   SIGNAL  (mirrors v12_vishal.py / v12_tradingview.pine exactly):
//     E2 = SMI(30,3,3) cross out of ±35 band, on the right side of its signal
//     E3 = break of the nearest swing high/low (pivot lr5) within 20 bars
//     E1 = VWAP — CONFIRM/CONVICTION ONLY (never triggers), shown as a tag
//     E2 OR E3 fires the trade. Window 09:30–14:45 IST. One position at a time.
//
//   EXIT LADDER (index points — the validated "futures-leg" exits):
//     hard SL : entry ∓ 1.5 × ATR(14)
//     arm     : when price runs +1.0 × ATR(14) in favour
//     trail   : once armed, ratchet the stop to SMA(8)  (close basis)
//     EOD     : force-close at 15:25 IST
//     guard   : stop opening new trades after 5 losing trades in a day
//
//   CE signal → LONG the index   ·   PE signal → SHORT the index.
//
// HOW TO USE: TradingView → NIFTY (5-minute) → Pine Editor → paste → "Add to
// chart". Open the Strategy Tester tab for the backtest. Use the SMI pane block
// at the bottom as a SECOND indicator if you want the oscillator view too.
// ════════════════════════════════════════════════════════════════════════════
//@version=6
strategy("V12 Vishal Rajput — FULL Strategy (5m NIFTY)", overlay=true,
         pyramiding=0, calc_on_every_tick=false, process_orders_on_close=true,
         default_qty_type=strategy.fixed, default_qty_value=1,
         initial_capital=100000, commission_type=strategy.commission.points,
         commission_value=0)

// ─────────────────────────────── inputs ─────────────────────────────────────
kLen       = input.int(30,    "SMI %K length",        group="Signal")
dLen       = input.int(3,     "SMI smooth",           group="Signal")
sigLen     = input.int(3,     "SMI signal",           group="Signal")
overbought = input.float(35.0,"E2 overbought (PE)",   group="Signal")
oversold   = input.float(-35.0,"E2 oversold (CE)",    group="Signal")
lookback   = input.int(20,    "E3 cluster lookback",  group="Signal")
lr         = input.int(5,     "E3 swing left/right",  group="Signal")
useE1      = input.bool(false,"Require E1 (VWAP) confirm to enter", group="Signal")

atrLen     = input.int(14,    "ATR length",           group="Exits")
slATR      = input.float(1.5, "Hard SL  (× ATR)",     group="Exits")
armATR     = input.float(1.0, "Arm trail (× ATR)",    group="Exits")
maLen      = input.int(8,     "Trail MA (SMA len)",   group="Exits")

useWin     = input.bool(true, "Only 09:30–14:45 IST entries", group="Session")
winStart   = input.int(570,   "Entry start (min of day)", group="Session")  // 09:30
winEnd     = input.int(885,   "Entry end   (min of day)", group="Session")  // 14:45
eodMin     = input.int(925,   "Force-close (min of day)", group="Session")  // 15:25
maxLosses  = input.int(5,     "Stop after N losses/day",  group="Session")

// ─────────────────────────────── indicators ─────────────────────────────────
f_ema2(src, len) => ta.ema(ta.ema(src, len), len)
hh   = ta.highest(high, kLen)
ll   = ta.lowest(low,  kLen)
smi  = 100 * f_ema2(close - (hh + ll) / 2, dLen) / (f_ema2(hh - ll, dLen) / 2)
smiS = ta.ema(smi, sigLen)
atrV = ta.atr(atrLen)
maV  = ta.sma(close, maLen)
vwap = ta.vwap(hlc3)

// ─────────────── E2 — SMI cross through band, on its signal's side ───────────
e2_ce = smi[1] <= oversold   and smi > oversold   and smi > smiS
e2_pe = smi[1] >= overbought and smi < overbought and smi < smiS

// ─────────────── E3 — break of nearest swing within the lookback ─────────────
ph = ta.pivothigh(high, lr, lr)
pl = ta.pivotlow(low,  lr, lr)
var float lastPH = na
var float lastPL = na
var int   phBar  = na
var int   plBar  = na
if not na(ph)
    lastPH := ph
    phBar  := bar_index - lr
if not na(pl)
    lastPL := pl
    plBar  := bar_index - lr
resOk = not na(lastPH) and (bar_index - phBar) <= lookback
supOk = not na(lastPL) and (bar_index - plBar) <= lookback
e3_ce = resOk and close[1] <= lastPH and close > lastPH
e3_pe = supOk and close[1] >= lastPL and close < lastPL

// ─────────────── E1 — VWAP confirm (tag / optional gate, never a trigger) ────
e1_ce = close > vwap
e1_pe = close < vwap

minOfDay = hour * 60 + minute
inWin    = not useWin or (minOfDay >= winStart and minOfDay <= winEnd)
isEOD    = minOfDay >= eodMin

ceRaw = (e2_ce or e3_ce)
peRaw = (e2_pe or e3_pe)
ceSig = ceRaw and (not useE1 or e1_ce)
peSig = peRaw and (not useE1 or e1_pe)

// ─────────────── daily loss guard ───────────────────────────────────────────
newDay = ta.change(time("D")) != 0
var int lossesToday = 0
if newDay
    lossesToday := 0
if ta.change(strategy.closedtrades) > 0
    if strategy.closedtrades.profit(strategy.closedtrades - 1) < 0
        lossesToday := lossesToday + 1

flat    = strategy.position_size == 0
canEnt  = inWin and not isEOD and flat and lossesToday < maxLosses

// ─────────────── entries ────────────────────────────────────────────────────
var float entryPx  = na
var float atrEntry = na
var bool  armed    = false
var float stopLvl  = na

if canEnt and ceSig
    strategy.entry("CE", strategy.long, comment="E2/E3 CE")
    entryPx  := close
    atrEntry := atrV
    armed    := false
    stopLvl  := close - slATR * atrV

if canEnt and peSig
    strategy.entry("PE", strategy.short, comment="E2/E3 PE")
    entryPx  := close
    atrEntry := atrV
    armed    := false
    stopLvl  := close + slATR * atrV

// ─────────────── exit management (arm → SMA trail → stop) ────────────────────
if strategy.position_size > 0                       // long (CE)
    if not armed and high >= entryPx + armATR * atrEntry
        armed := true
    if armed
        stopLvl := math.max(stopLvl, maV)
    if isEOD
        strategy.close("CE", comment="EOD")
    else
        strategy.exit("CE-x", from_entry="CE", stop=stopLvl,
             comment = armed ? "TRAIL" : "SL")

if strategy.position_size < 0                       // short (PE)
    if not armed and low <= entryPx - armATR * atrEntry
        armed := true
    if armed
        stopLvl := math.min(stopLvl, maV)
    if isEOD
        strategy.close("PE", comment="EOD")
    else
        strategy.exit("PE-x", from_entry="PE", stop=stopLvl,
             comment = armed ? "TRAIL" : "SL")

// ─────────────── visuals ────────────────────────────────────────────────────
plot(vwap, "VWAP", color.new(color.orange, 0))
plot(strategy.position_size != 0 ? stopLvl : na, "Stop", color.new(color.fuchsia, 0),
     style=plot.style_linebr)
plotshape(canEnt and e2_ce, "E2 CE", shape.triangleup,  location.belowbar, color.new(color.green, 0), size=size.small, text="E2")
plotshape(canEnt and e3_ce, "E3 CE", shape.triangleup,  location.belowbar, color.new(color.lime,  0), size=size.tiny,  text="E3")
plotshape(canEnt and e2_pe, "E2 PE", shape.triangledown,location.abovebar, color.new(color.red,    0), size=size.small, text="E2")
plotshape(canEnt and e3_pe, "E3 PE", shape.triangledown,location.abovebar, color.new(color.maroon, 0), size=size.tiny,  text="E3")

alertcondition(canEnt and ceSig, "V12 CE", "V12 Vishal Rajput — CE (long) entry, 5m NIFTY")
alertcondition(canEnt and peSig, "V12 PE", "V12 Vishal Rajput — PE (short) entry, 5m NIFTY")


// ════════════════════════════════════════════════════════════════════════════
