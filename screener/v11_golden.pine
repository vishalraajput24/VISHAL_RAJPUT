//@version=6
// =====================================================================
//  V11 GOLDEN  — TradingView port of the VRL NIFTY weekly-options bot
//  Mirrors the LOCKED values in CLAUDE.md (dte>=2 absolute gate).
//
//  USE: add to the 1-MINUTE chart of ONE option leg (the leg you might
//  BUY). Pick CE/PE below. The OPP DECAY gate reads the OPPOSITE leg —
//  set "Opposite leg symbol" (or leave blank to run MOMENTUM-only).
//  Set chart timezone to Asia/Kolkata so the window/EOD line up.
// =====================================================================
strategy("V11 Golden (NIFTY weekly options)",
     overlay                 = true,
     pyramiding              = 0,
     initial_capital         = 100000,
     default_qty_type        = strategy.fixed,
     default_qty_value       = 65,            // 1 lot = 65 qty
     calc_on_every_tick      = false,
     process_orders_on_close = true)

// ---------------------------------------------------------------------
//  INPUTS  (defaults = LOCKED dte>=2 values from CLAUDE.md)
// ---------------------------------------------------------------------
grpGate  = "Entry gates (dte>=2 absolute)"
emaLen   = input.int(9,     "EMA length",            group=grpGate, minval=1)
momGap   = input.float(3.5, "MOMENTUM min gap (pts)", group=grpGate, step=0.1) // close >= ema9_high + 3.5
decayLow = input.float(-9.0,"OPP DECAY band low",     group=grpGate, step=0.1)
decayHigh= input.float(-7.0,"OPP DECAY band high",    group=grpGate, step=0.1)

grpOpp  = "Opposite leg (for OPP DECAY)"
legType = input.string("CE", "This chart is a ...", options=["CE","PE"], group=grpOpp,
     tooltip="CE if charting a call you might BUY, PE if a put. Only changes arrow/alert text — gate math is identical.")
oppSym  = input.symbol("",  "Opposite leg symbol (the OTHER side's premium)", group=grpOpp,
     tooltip="Charting the CE? put the matching PE here (and vice-versa). Leave blank to DISABLE decay and trade MOMENTUM-only.")

grpWin   = "Entry window (IST)"
useWindow= input.bool(true, "Restrict entries to window", group=grpWin)
winStart = input.session("1000-1430", "Entry window", group=grpWin,
     tooltip="V11 live window 10:00-14:30 IST. Set chart timezone to Asia/Kolkata.")
eodTime  = input.session("1515-1516", "EOD force-close minute", group=grpWin)

grpLad      = "Exit ladder (peak-based, points)"
protectPeak = input.float(9,  "PROTECT  peak >=",        group=grpLad) // -> entry-2
protectSL   = input.float(-2, "PROTECT  SL = entry +",   group=grpLad)
lock4Peak   = input.float(11, "LOCK_4   peak >=",        group=grpLad) // -> entry+4
lock4SL     = input.float(4,  "LOCK_4   SL = entry +",   group=grpLad)
trailPeak   = input.float(15, "TRAIL_10 peak >=",        group=grpLad) // -> max(entry+9, peak-10)
trailFloor  = input.float(9,  "TRAIL_10 floor = entry +",group=grpLad)
trailGive   = input.float(10, "TRAIL_10 give-back (peak -)", group=grpLad)
l25Peak     = input.float(25, "LOCK_25  peak >=",        group=grpLad) // -> max(entry+25, peak-5)
l25Floor    = input.float(25, "LOCK_25  floor = entry +",group=grpLad)
l25Give     = input.float(5,  "LOCK_25  give-back (peak -)", group=grpLad)
slCap       = input.float(10, "Initial SL cap (entry - X)", group=grpLad) // capped at entry-10
slFallback  = input.float(5,  "SL fallback (entry - X)",    group=grpLad)

grpDiag = "Diagnostics"
showDiag= input.bool(true, "Show gate diagnostics", group=grpDiag)
showTbl = input.bool(true, "Show live info table",  group=grpDiag)

// ---------------------------------------------------------------------
//  EMA9 of HIGHS and EMA9 of LOWS  (the two V11 bands)
// ---------------------------------------------------------------------
ema9_high = ta.ema(high, emaLen)
ema9_low  = ta.ema(low,  emaLen)
plot(ema9_high, "EMA9 high", color.new(color.lime, 0))
plot(ema9_low,  "EMA9 low",  color.new(color.red,  0))

// ---------------------------------------------------------------------
//  OPPOSITE LEG premium + its EMA9_low  (for OPP DECAY)
// ---------------------------------------------------------------------
oppOn = str.length(oppSym) > 0
[oppClose, oppEma9Low] = request.security(oppOn ? oppSym : syminfo.tickerid, timeframe.period,
     [close, ta.ema(low, emaLen)], lookahead=barmerge.lookahead_off)

oppMargin  = oppClose - oppEma9Low                     // close - ema9_low of OPPOSITE leg
oppHasData = not oppOn or not na(oppClose)             // false => TV has no data for the opposite leg
// No opp data => treat decay as PASS (MOMENTUM-only) instead of silently killing every entry via na.
decayOK    = not oppOn ? true : (na(oppClose) ? true : (oppMargin >= decayLow and oppMargin <= decayHigh))

// ---------------------------------------------------------------------
//  GATES
// ---------------------------------------------------------------------
momentumOK = close >= ema9_high + momGap
inWindow   = not useWindow or not na(time(timeframe.period, winStart, "Asia/Kolkata"))
isEOD      = not na(time(timeframe.period, eodTime, "Asia/Kolkata"))
entrySignal= momentumOK and decayOK and inWindow and not isEOD

// ---------------------------------------------------------------------
//  CLEAN BUY ARROW (confirmed bar only — matches the bot's candle-close fire)
// ---------------------------------------------------------------------
buyNow       = entrySignal and strategy.position_size == 0
buyConfirmed = buyNow and barstate.isconfirmed         // non-repainting: fires on the CLOSED candle
plotshape(buyConfirmed, "BUY", shape.arrowup, location.belowbar, color.new(color.lime,0),
     size=size.large, text="BUY", textcolor=color.white)

// ---------------------------------------------------------------------
//  DIAGNOSTICS — see WHICH gate blocks (toggle off once happy)
// ---------------------------------------------------------------------
diagOK = showDiag and barstate.isconfirmed
plotshape(diagOK and momentumOK,                 "MOMENTUM ok",   shape.triangleup, location.belowbar, color.new(color.aqua,0),   size=size.tiny, text="M")
plotshape(diagOK and oppOn and decayOK,          "DECAY ok",      shape.circle,     location.belowbar, color.new(color.yellow,0), size=size.tiny, text="D")
plotshape(diagOK and oppOn and not oppHasData,   "NO OPP DATA",   shape.xcross,     location.abovebar, color.new(color.red,0),    size=size.tiny, text="no-data")
plotshape(diagOK and not inWindow,               "Out of window", shape.cross,      location.bottom,   color.new(color.gray,60),  size=size.tiny)

// ---------------------------------------------------------------------
//  LIVE INFO TABLE — verify IST time + distance to the trigger
// ---------------------------------------------------------------------
var table t = table.new(position.top_right, 2, 8, border_width=1)
f_row(i, k, v, col) =>
    table.cell(t, 0, i, k, text_color=color.white, text_size=size.small, bgcolor=color.new(color.black,0))
    table.cell(t, 1, i, v, text_color=col,         text_size=size.small, bgcolor=color.new(color.black,0))

if showTbl and barstate.islast
    needPx = ema9_high + momGap                        // exact close needed for MOMENTUM
    gap    = close - needPx                            // >=0 means momentum passing
    istNow = str.format_time(time_close, "HH:mm:ss", "Asia/Kolkata")
    f_row(0, "IST candle", istNow,                                                                      color.aqua)
    f_row(1, "Leg",        legType,                                                                     color.aqua)
    f_row(2, "Close",      str.tostring(close, "#.##"),                                                 color.white)
    f_row(3, "Need (>=)",  str.tostring(needPx, "#.##"),                                                color.yellow)
    f_row(4, "Mom gap",    str.tostring(gap, "#.##"),                                                   gap >= 0 ? color.lime : color.red)
    f_row(5, "Opp margin", oppOn ? (na(oppClose) ? "NO DATA" : str.tostring(oppMargin, "#.##")) : "off", decayOK ? color.lime : color.red)
    f_row(6, "In window",  inWindow ? "YES" : "NO",                                                     inWindow ? color.lime : color.red)
    f_row(7, "READY",      buyNow ? ("BUY " + legType) : "wait",                                        buyNow ? color.lime : color.gray)

// ---------------------------------------------------------------------
//  ALERTS — fire on the confirmed candle so timing matches the bot
// ---------------------------------------------------------------------
alertcondition(buyConfirmed, "V11 BUY signal", "V11 BUY {{ticker}} @ {{close}}")
if buyConfirmed
    alert("V11 BUY " + legType + " " + syminfo.ticker + " @ " + str.tostring(close, "#.##") +
         " | " + str.format_time(time_close, "HH:mm:ss", "Asia/Kolkata") + " IST", alert.freq_once_per_bar_close)

// ---------------------------------------------------------------------
//  ENTRY  (buy the charted leg; long-only — option premium long)
// ---------------------------------------------------------------------
if entrySignal and strategy.position_size == 0
    strategy.entry("V11", strategy.long, comment="V11 BUY")

// ---------------------------------------------------------------------
//  EXIT LADDER  (peak-based, recomputed every bar while in trade)
// ---------------------------------------------------------------------
var float entryPx = na
var float initSL  = na
var float peakLtp = na

justEntered = strategy.position_size > 0 and strategy.position_size[1] == 0
if justEntered
    entryPx := strategy.position_avg_price
    rawSL   = ema9_low[1]                               // ema9_low of breakout candle
    capped  = entryPx - slCap
    initSL  := rawSL >= entryPx ? entryPx - slFallback : math.max(rawSL, capped)
    peakLtp := high

float slLevel = na
if strategy.position_size > 0
    peakLtp := math.max(peakLtp, high)
    peakPnl = peakLtp - entryPx
    sl = initSL
    if peakPnl >= protectPeak
        sl := math.max(sl, entryPx + protectSL)
    if peakPnl >= lock4Peak
        sl := math.max(sl, entryPx + lock4SL)
    if peakPnl >= trailPeak
        sl := math.max(sl, entryPx + trailFloor, peakLtp - trailGive)
    if peakPnl >= l25Peak
        sl := math.max(sl, entryPx + l25Floor, peakLtp - l25Give)
    slLevel := sl
    strategy.exit("V11 SL", from_entry="V11", stop=sl)
    if isEOD
        strategy.close("V11", comment="EOD_EXIT")

plot(strategy.position_size > 0 ? slLevel : na, "Active SL", color.orange, style=plot.style_stepline)
